# ─────────────────────────────────────────────────────────────────────────────
# Waiting-list form → rapidmail (API v3), double opt-in (section 11)
# Copy this file to `.env.local` and fill in the values. `.env.local` is gitignored.
# Full walkthrough: PROJECT-LOG.md → "11 — Form".
# Server-only — set the SAME three vars in Vercel (Production, Preview, Development).
# ─────────────────────────────────────────────────────────────────────────────

# rapidmail API v3 credentials. In rapidmail: Settings → API → create an API key;
# it is issued as a user + password pair used for HTTP Basic auth.
RAPIDMAIL_API_USERNAME=
RAPIDMAIL_API_PASSWORD=

# Numeric id of the target recipient list new signups are added to.
# In rapidmail: Recipient lists → the list → its id (also visible in the URL).
RAPIDMAIL_RECIPIENTLIST_ID=
